# =================================================================
# 1. 深度学习模型权重与检查点 (必须忽略，防止 Git 仓库爆炸)
# =================================================================
checkpoints/
nodes/
*.pth
*.pt
*.ckpt
*.bin
*.weights
*.h5

# =================================================================
# 2. 实验输出、日志与可视化 (防止上传数万个小文件)
# =================================================================
output/
outputs/
results/
runs/                # Tensorboard 默认路径
wandb/               # Weights & Biases 实验日志
lightning_logs/      # PyTorch Lightning 日志
tensorboard_logs/
*.log
*.events.* # Tensorboard 事件文件

# =================================================================
# 3. 数据集与大文件
# =================================================================

*.zip
*.tar
*.gz
*.7z
*.npy
*.npz
*.csv
*.jsonl

# =================================================================
# 4. Python 系统文件与缓存
# =================================================================
__pycache__/


# =================================================================
# 5. 虚拟环境
# =================================================================
venv/
env/
.env
.venv/
conda-env/

# =================================================================
# 6. IDE 与系统文件
# =================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =================================================================
# 7. 图像文件处理 (特别注意)
# =================================================================
# 默认忽略所有图片，防止把推理结果传上去
*.png
*.jpg
*.jpeg
*.gif

# 但允许保留 assets 文件夹中的图片 (用于展示在 README 中的架构图、效果图)
!figure/*.png
!figure/*.jpg
!figure/*.jpeg
!figure/*.gif